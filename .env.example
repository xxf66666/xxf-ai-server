# ============ Core ============
NODE_ENV=development
LOG_LEVEL=info

# ============ Server ============
SERVER_HOST=0.0.0.0
SERVER_PORT=8787
# Public origin of the API gateway, used by admin UI
PUBLIC_API_URL=http://localhost:8787

# ============ Admin UI ============
WEB_PORT=3000
PUBLIC_WEB_URL=http://localhost:3000

# ============ Database ============
DATABASE_URL=postgresql://xxfai:xxfai@localhost:5432/xxfai

# ============ Redis ============
REDIS_URL=redis://localhost:6379

# ============ Secrets ============
# Used to AES-256-GCM encrypt OAuth tokens at rest. 32-byte hex (64 chars).
ENCRYPTION_KEY=change-me-to-64-hex-chars-0000000000000000000000000000000000000000
# Used to sign admin session JWTs.
JWT_SECRET=change-me-to-a-long-random-string
# Single bearer used to gate /admin/v1/* until proper login lands in P3.
# Leave unset to disable the admin API entirely.
ADMIN_BOOTSTRAP_TOKEN=

# ============ Rate limit ============
# Per-API-key limit on /v1/* (requests per window).
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_SECONDS=60

# ============ Email (SMTP) ============
# Transactional email for verification links. If SMTP_HOST / SMTP_USER /
# SMTP_PASS aren't all set, email verification is skipped (users marked
# verified on register). Works with any SMTP provider:
#   - Tencent Cloud SES: smtp.qcloudmail.com:465
#   - QQ Exmail:         smtp.exmail.qq.com:465
#   - Gmail:             smtp.gmail.com:465 (app password required)
#   - SendGrid:          smtp.sendgrid.net:587
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
# From address. Must match / be authorized by SMTP_USER's verified sender.
MAIL_FROM=xxf-ai-server <noreply@localhost>

# ============ OAuth clients ============
# Placeholder IDs — to be filled in by ops when upstream OAuth apps are registered.
CLAUDE_OAUTH_CLIENT_ID=
CHATGPT_OAUTH_CLIENT_ID=

# ============ Egress proxy (optional, recommended once >3 accounts) ============
# Comma-separated list of upstream proxy URLs, e.g. http://user:pass@host:port
EGRESS_PROXIES=

# ============ Outbound HTTP proxy (dev only, when behind a firewall) ============
# If set, the server routes every outbound fetch through this proxy — used so
# a local dev box behind a firewall can reach api.anthropic.com. On a cloud
# VM with direct egress, leave these empty.
# HTTPS_PROXY=http://127.0.0.1:7897
# HTTP_PROXY=http://127.0.0.1:7897
# NO_PROXY=localhost,127.0.0.1
