# ============ Core ============
NODE_ENV=development
LOG_LEVEL=info

# ============ Server ============
SERVER_HOST=0.0.0.0
SERVER_PORT=8787
# Public origin of the API gateway, used by admin UI
PUBLIC_API_URL=http://localhost:8787

# ============ Admin UI ============
WEB_PORT=3000
PUBLIC_WEB_URL=http://localhost:3000

# ============ Database ============
DATABASE_URL=postgresql://xxfai:xxfai@localhost:5432/xxfai

# ============ Redis ============
REDIS_URL=redis://localhost:6379

# ============ Secrets ============
# Used to AES-256-GCM encrypt OAuth tokens at rest. 32-byte hex (64 chars).
ENCRYPTION_KEY=change-me-to-64-hex-chars-0000000000000000000000000000000000000000
# Used to sign admin session JWTs.
JWT_SECRET=change-me-to-a-long-random-string
# Single bearer used to gate /admin/v1/* until proper login lands in P3.
# Leave unset to disable the admin API entirely.
ADMIN_BOOTSTRAP_TOKEN=

# ============ OAuth clients ============
# Placeholder IDs — to be filled in by ops when upstream OAuth apps are registered.
CLAUDE_OAUTH_CLIENT_ID=
CHATGPT_OAUTH_CLIENT_ID=

# ============ Egress proxy (optional, recommended once >3 accounts) ============
# Comma-separated list of upstream proxy URLs, e.g. http://user:pass@host:port
EGRESS_PROXIES=
